{
  "name": "universal-mail-merger",
  "version": "3.0.0",
  "description": "True one-to-one mail merger Chrome extension with AI agent MCP, skills, and catalog discovery.",
  "type": "commonjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "ai:discover": "ts-node src/discover.ts",
    "ai:mcp": "ts-node src/discover.ts --mcp",
    "ai:skills": "ts-node src/discover.ts --skills",
    "ai:catalog": "ts-node src/discover.ts --catalog",
    "ai:validate": "jest",
    "sync:extension": "node scripts/sync-extension.js",
    "start": "ts-node src/server.ts",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
